@startuml merge-merger-sequence
title Merge Merger Sequence

participant "SecurityPolicyMergeRunner.FlushPartitionAfterShadowing" as RunnerFlush
participant "SecurityPolicyShadowAnalyzer" as ShadowAnalyzer
participant "EffectivePolicyConditionContainment" as Containment
participant "emitMergedPolicies callback" as Output

participant "SecurityPolicyMerger" as Merger
participant "AtomicMergeCandidateDeduplicator" as Deduplicator
participant "MergedSecurityPolicyFactory" as PolicyFactory
participant "MutableMergedSecurityPolicy" as MutablePolicy
participant "ServiceMerger" as ServiceMerger
participant "SourceAddressMerger" as SourceMerger
participant "DestinationAddressMerger" as DestinationMerger
participant "OriginalRuleMerger" as OriginalRuleMerger
participant "HighSimilarityPolicyRecomposer" as Recomposer
participant "SmallWellKnownDestinationPortMatcher" as WellKnownMatcher
participant "ConfiguredIdentitySetOperations" as ConfiguredIdentity

note over ServiceMerger, OriginalRuleMerger
  MergeBySignature / MergeSignatureSet /
  traceability absorption are provided by the SignatureBasedMergerBase base class
end note

note over ConfiguredIdentity
  Signatures use PolicyConditionCanonicalOrder:
  address Start / Finish,
  service any -> Kind -> protocol / destination / source,
  application Ordinal.
end note

RunnerFlush -> ShadowAnalyzer : Analyze(partitionCandidates)
activate ShadowAnalyzer
loop compare non-shadowed candidate and later candidate
  ShadowAnalyzer -> Containment : ApplicationCovers(...)
  Containment --> ShadowAnalyzer : application covered
  ShadowAnalyzer -> Containment : AddressCovers(source / destination)
  Containment --> ShadowAnalyzer : address covered
  ShadowAnalyzer -> Containment : ServiceCovers(service)
  Containment --> ShadowAnalyzer : service covered
end
ShadowAnalyzer --> RunnerFlush : NonShadowedIndices + ShadowingRelations
deactivate ShadowAnalyzer

alt shadowed policies exist
  RunnerFlush -> RunnerFlush : materialize nonShadowedCandidates from NonShadowedIndices
  loop each shadowing relation
    RunnerFlush -> RunnerFlush : AbsorbShadowedAtomicPolicy(frontCandidate, shadowedCandidate)\nunion OriginalPolicyNames and update MinimumIndex / MaximumIndex
  end
else no shadowed policies
  RunnerFlush -> RunnerFlush : keep partitionCandidates as-is
end

RunnerFlush -> Merger : MergePartition(partitionCandidates)
activate Merger
Merger -> Merger : split allow / non-Allow candidates

alt allow policies exist
  Merger -> Deduplicator : RemoveContainedPolicies(allowPolicies)
  activate Deduplicator
  Deduplicator -> Deduplicator : clone candidates for comparison
  loop compare allow candidate pairs
    Deduplicator -> Containment : AddressCovers(source / destination)
    Containment --> Deduplicator : address covered
    Deduplicator -> Containment : ApplicationCovers(...)
    Containment --> Deduplicator : application covered
    Deduplicator -> Containment : ServiceCovers(service)
    Containment --> Deduplicator : service covered
    alt one candidate contains the other
      Deduplicator -> Deduplicator : absorb traceability and mark removed
    else no containment
      Deduplicator -> Deduplicator : keep both candidates
    end
  end
  Deduplicator --> Merger : deduplicated allow policies
  deactivate Deduplicator

  loop create seed merged policies
    Merger -> PolicyFactory : CreateFromAtomic(policy)
    PolicyFactory --> Merger : single mutable merged policy
  end

  Merger -> ServiceMerger : Merge(allowPoliciesAfterDeduplication)
  activate ServiceMerger
  ServiceMerger -> ServiceMerger : CreateMergeSignature(policy)
  ServiceMerger -> PolicyFactory : ClonePolicy(basePolicy)
  PolicyFactory --> ServiceMerger : cloned mutable policy
  ServiceMerger -> ServiceMerger : MergeSignatureSet(...)\nunion Services and traceability per signature
  ServiceMerger --> Merger : service-merged mutable policies
  deactivate ServiceMerger

  Merger -> SourceMerger : Merge(allowPoliciesAfterServiceMerge)
  activate SourceMerger
  SourceMerger -> SourceMerger : CreateMergeSignature(policy)
  SourceMerger -> PolicyFactory : ClonePolicy(basePolicy)
  PolicyFactory --> SourceMerger : cloned mutable policy
  SourceMerger -> SourceMerger : MergeSignatureSet(...)\nunion SourceAddresses and traceability per signature
  SourceMerger --> Merger : source-merged mutable policies
  deactivate SourceMerger

  Merger -> DestinationMerger : Merge(allowPoliciesAfterSourceMerge)
  activate DestinationMerger
  DestinationMerger -> DestinationMerger : CreateMergeSignature(policy)
  DestinationMerger -> WellKnownMatcher : TryGetSmallWellKnownDestinationPorts(signature services)
  WellKnownMatcher --> DestinationMerger : matching ports / no match
  alt keep destination addresses separated
    DestinationMerger -> DestinationMerger : BuildDestinationAddressSetSignature(destination set)
  else merge destination addresses
    DestinationMerger -> DestinationMerger : keep original destination merge group
  end
  DestinationMerger -> PolicyFactory : ClonePolicy(basePolicy)
  PolicyFactory --> DestinationMerger : cloned mutable policy
  DestinationMerger -> DestinationMerger : MergeSignatureSet(...)\nunion DestinationAddresses and traceability
  DestinationMerger --> Merger : destination-merged mutable allow policies
  deactivate DestinationMerger

  Merger -> Recomposer : RecomposeMutable(allowPoliciesAfterThreePasses)
  activate Recomposer
  Recomposer -> Recomposer : CreateRecompositionSignature(policy)
  loop each same FromZone / ToZone / Application / Action / GroupId group
    loop while recomposable pair exists
      Recomposer -> ConfiguredIdentity : IntersectByConfiguredIdentity(destination / service)
      ConfiguredIdentity --> Recomposer : common destination / services
      Recomposer -> ConfiguredIdentity : UnionByConfiguredIdentity(source)
      ConfiguredIdentity --> Recomposer : union sources
      alt destination and service axes reach threshold
        Recomposer -> WellKnownMatcher : TryGetSmallWellKnownDestinationPorts(commonServices)
        WellKnownMatcher --> Recomposer : matching ports / no match
        alt common services are small well-known destination ports
          Recomposer -> Recomposer : skip this pair only
        else valid pair
          Recomposer -> PolicyFactory : CreateFromTemplate(...union-source common policy...)
          PolicyFactory --> Recomposer : common mutable policy
          Recomposer -> ConfiguredIdentity : SubtractByConfiguredIdentity(destination / service)
          ConfiguredIdentity --> Recomposer : residual destination / services
          Recomposer -> PolicyFactory : CreateFromTemplate(...destination / service residuals with original sources...)
          PolicyFactory --> Recomposer : residual mutable policies
          Recomposer -> Recomposer : settle residuals and requeue common policy
        end
      else below threshold
        Recomposer -> Recomposer : ignore pair
      end
    end
  end
  Recomposer --> Merger : recomposed mutable allow policies
  deactivate Recomposer
else no allow policies
  Merger -> Merger : skip allow merge path
end

alt non-Allow policies exist
  loop create non-Allow merged policies
    Merger -> PolicyFactory : CreateFromAtomic(policy)
    PolicyFactory --> Merger : single mutable merged policy
  end
  Merger -> OriginalRuleMerger : Merge(nonAllowMergedPolicies)
  activate OriginalRuleMerger
  OriginalRuleMerger -> OriginalRuleMerger : CreateMergeSignature(policy)
  OriginalRuleMerger -> PolicyFactory : ClonePolicy(basePolicy)
  PolicyFactory --> OriginalRuleMerger : cloned mutable policy
  OriginalRuleMerger -> OriginalRuleMerger : MergeSignatureSet(...)\nunion all collections and traceability
  OriginalRuleMerger --> Merger : non-Allow mutable merged policy
  deactivate OriginalRuleMerger
else no non-Allow policies
  Merger -> Merger : skip non-Allow merge path
end

Merger -> Merger : sort mutable policies by MinimumIndex / MaximumIndex
loop each sorted mutable policy
  Merger -> MutablePolicy : ToMergedSecurityPolicy()
  MutablePolicy --> Merger : read-only merged policy
end
Merger --> RunnerFlush : merged policies
deactivate Merger

RunnerFlush --> Output : emitMergedPolicies(mergedPolicies)
Output --> RunnerFlush : void
RunnerFlush -> RunnerFlush : partitionCandidates.Clear()
RunnerFlush --> RunnerFlush : flushed policies

@enduml
